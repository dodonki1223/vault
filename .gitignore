# Local-only project notes. Keep actual project contents out of git.
projects/*
!projects/
!projects/README.md
!projects/active/
projects/active/*
!projects/active/README.md
!projects/archive/
projects/archive/*
!projects/archive/README.md

# Local-only notes. Keep sensitive, private, or not-for-commit material here.
notes/local/*
!notes/local/
!notes/local/README.md

# Node.js dependencies and local tool output.
node_modules/
npm-debug.log*
pnpm-debug.log*
